# ──────────────────────────────────────────────────────────────────
# Step Korean — Environment Variables Template
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────

# Firebase — get these from your Firebase project settings
# https://console.firebase.google.com → Project Settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Public page URLs — safe to share but kept configurable
VITE_NOTION_URL=https://notion.so
VITE_PAYHIP_URL=https://payhip.com/StepKorean
