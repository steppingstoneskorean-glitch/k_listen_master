if git diff --cached --name-only | grep -q "^src/data/hardcodedQuizzes.ts$"; then
  node scripts/translate-explanations.cjs
  git add src/data/hardcodedQuizzes.ts scripts/.i18n-cache.json
fi
# 문법 아티클 번역은 pre-commit 에서 자동 실행하지 않는다 —
# 문자열이 많아 커밋이 수 분간 멈추고, 번역은 사람이 검수하는 것이 전제이기 때문.
# 새 글을 쓴 뒤에는 직접 실행할 것:  npm run i18n:grammar
if git diff --cached --name-only | grep -q "^src/data/grammarArticles.ts$"; then
  if ! git diff --cached --name-only | grep -q "^src/data/grammarTranslations.json$"; then
    echo "[grammar-i18n] ℹ️  grammarArticles.ts 가 변경됐습니다. 번역을 갱신하려면: npm run i18n:grammar"
  fi
fi
